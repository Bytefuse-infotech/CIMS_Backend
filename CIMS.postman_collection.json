    {
      "name": "Fees (/api/v1)",
      "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{tenantAccessToken}}" }] },
      "item": [
        {
          "name": "List fee plans",
          "request": { "method": "GET", "header": [], "url": { "raw": "{{baseUrl}}/api/v1/fee-plans", "host": ["{{baseUrl}}"], "path": ["api", "v1", "fee-plans"] } }
        },
        {
          "name": "Create fee plan (admin)",
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const b = pm.response.json(); if (b._id) pm.collectionVariables.set('feePlanId', b._id);"] } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Annual Fee 2026\",\n  \"totalAmount\": 60000,\n  \"batchId\": \"{{batchId}}\",\n  \"splitInto\": 3,\n  \"firstDueDate\": \"2026-08-01\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/fee-plans", "host": ["{{baseUrl}}"], "path": ["api", "v1", "fee-plans"] },
            "description": "Provide explicit `installments` array OR use `splitInto` + `firstDueDate` to auto-split.\n\nExplicit example:\n```\n\"installments\": [ { \"label\": \"Term 1\", \"amount\": 20000, \"dueDate\": \"2026-08-01\" } ]\n```"
          }
        },
        {
          "name": "Generate invoices (admin)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"studentIds\": [\"{{studentId}}\"]\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/fee-plans/{{feePlanId}}/generate-invoices", "host": ["{{baseUrl}}"], "path": ["api", "v1", "fee-plans", "{{feePlanId}}", "generate-invoices"] },
            "description": "`studentIds` optional — omit to generate for all students in the plan's batch."
