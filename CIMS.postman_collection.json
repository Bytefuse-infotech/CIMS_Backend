          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const b = pm.response.json();",
                  "if (b.accessToken) pm.collectionVariables.set('platformAccessToken', b.accessToken);",
                  "if (b.refreshToken) pm.collectionVariables.set('platformRefreshToken', b.refreshToken);",
                  "pm.test('has tokens', () => pm.expect(b.accessToken).to.be.a('string'));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"{{platformEmail}}\",\n  \"password\": \"{{platformPassword}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/platform/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["platform", "v1", "auth", "login"] },
            "description": "Optional `totp` field accepted (2FA reserved, not enforced)."
