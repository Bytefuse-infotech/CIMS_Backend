# Server
PORT=3000
NODE_ENV=development

# Mongo (local docker-compose)
MONGO_URI=mongodb://localhost:27017/coaching

# JWT — two separate realms, distinct secrets so tokens are never interchangeable
TENANT_JWT_SECRET=dev-tenant-secret-change-me
TENANT_JWT_EXPIRES=15m
TENANT_REFRESH_SECRET=dev-tenant-refresh-secret-change-me
TENANT_REFRESH_EXPIRES=7d

PLATFORM_JWT_SECRET=dev-platform-secret-change-me
PLATFORM_JWT_EXPIRES=15m
PLATFORM_REFRESH_SECRET=dev-platform-refresh-secret-change-me
PLATFORM_REFRESH_EXPIRES=7d

# Impersonation tokens are short-lived tenant tokens minted from the platform surface
IMPERSONATION_JWT_EXPIRES=10m

# Rate limiting (login endpoints)
THROTTLE_TTL=60000
THROTTLE_LIMIT=10

# --- Integrations (all optional; unset = stub mode) ---
# Razorpay (fee payments from parents)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# FCM push (service-account JSON as a single-line string)
FCM_CREDENTIALS_JSON=

# CDN / object storage (S3-compatible) for materials + receipts
CDN_ENDPOINT=
CDN_BUCKET=
CDN_REGION=auto
CDN_ACCESS_KEY_ID=
CDN_SECRET_ACCESS_KEY=
CDN_PUBLIC_BASE_URL=
